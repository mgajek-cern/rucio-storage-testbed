{
  "realm": "rucio",
  "enabled": true,
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 1,
  "roles": {
    "realm": [
      { "name": "offline_access", "description": "Role for creating offline tokens" }
    ]
  },
  "groups": [
    {
      "name": "rucio",
      "path": "/rucio",
      "subGroups": [
        { "name": "admins", "path": "/rucio/admins" },
        { "name": "users", "path": "/rucio/users" }
      ]
    },
    {
      "name": "atlas",
      "path": "/atlas",
      "subGroups": [
        { "name": "production", "path": "/atlas/production" },
        { "name": "users", "path": "/atlas/users" }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "rucio-oidc",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "rucio-oidc-secret",
      "publicClient": false,
      "redirectUris": [
        "http://rucio-oidc/auth/oidc_token",
        "http://rucio-oidc/auth/oidc_code",
        "http://rucio-oidc/auth/oidc_redirect"
      ],
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "openid", "profile", "email", "wlcg", "fts",
        "storage.read", "storage.modify",
        "storage.read:/data", "storage.modify:/data",
        "storage.read:/", "storage.modify:/",
        "aud:fts-oidc",
        "aud:xrd3",
        "aud:xrd4",
        "aud:storm1",
        "aud:storm2"
      ],
      "optionalClientScopes": [
        "offline_access"
      ],
      "attributes": {
        "oidc.ciba.grant.enabled": "false",
        "oauth2.device.authorization.grant.enabled": "false",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false",
        "token.exchange.standard.flow.enabled": "true",
        "can.delegate.tokens": "true"
      }
    },
    {
      "clientId": "fts-oidc",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "fts-oidc-secret",
      "defaultClientScopes": [ "openid", "wlcg", "fts" ]
    },
    { "clientId": "storm1", "enabled": true, "publicClient": true },
    { "clientId": "storm2", "enabled": true, "publicClient": true },
    { "clientId": "STORM1", "enabled": true, "publicClient": true },
    { "clientId": "STORM2", "enabled": true, "publicClient": true }
  ],
  "users": [
    {
      "username": "jdoe2",
      "enabled": true,
      "email": "jdoe2@rucio",
      "emailVerified": true,
      "realmRoles": [ "offline_access" ],
      "credentials": [
        { "type": "password", "value": "secret", "temporary": false }
      ],
      "groups": [ "/rucio/users", "/atlas/users" ]
    },
    {
      "username": "adminuser",
      "enabled": true,
      "email": "admin@rucio",
      "emailVerified": true,
      "realmRoles": [ "offline_access" ],
      "credentials": [
        { "type": "password", "value": "admin123", "temporary": false }
      ],
      "groups": [ "/rucio/admins", "/atlas/production" ]
    }
  ],
  "clientScopes": [
    {
      "name": "wlcg",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "wlcg-version",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "wlcg\\.ver",
            "claim.value": "1.0",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "nbf-patch",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "nbf",
            "claim.value": "1700000000",
            "jsonType.label": "long",
            "access.token.claim": "true"
          }
        },
        {
          "name": "wlcg-groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "wlcg\\.groups",
            "full.path": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    { "name": "fts", "protocol": "openid-connect" },
    { "name": "storage.read", "protocol": "openid-connect" },
    { "name": "storage.modify", "protocol": "openid-connect" },
    { "name": "storage.read:/data", "protocol": "openid-connect" },
    { "name": "storage.modify:/data", "protocol": "openid-connect" },
    { "name": "storage.read:/", "protocol": "openid-connect" },
    { "name": "storage.modify:/", "protocol": "openid-connect" },

    {
      "name": "aud:fts-oidc",
      "description": "Adds fts-oidc to the token's aud claim. Request alongside 'fts' scope to get an FTS-submission token.",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-fts-oidc",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "fts-oidc",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "aud:storm1",
      "description": "Adds https://storm1:8443 to the token's aud claim for StoRM WebDAV validation on storm1.",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-storm1",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "https://storm1:8443",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "aud:storm2",
      "description": "Adds https://storm2:8443 to the token's aud claim for StoRM WebDAV validation on storm2.",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-storm2",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "https://storm2:8443",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "aud:xrd3",
      "description": "Adds https://xrd3:1094 to the token's aud claim for SciTokens validation on xrd3.",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-xrd3",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "https://xrd3:1094",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "aud:xrd4",
      "description": "Adds https://xrd4:1094 to the token's aud claim for SciTokens validation on xrd4.",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-xrd4",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "https://xrd4:1094",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "sslRequired": "none"
}
