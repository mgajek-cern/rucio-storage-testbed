{
  "realm": "rucio",
  "enabled": true,
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 1,
  "groups": [
    {
      "name": "rucio",
      "path": "/rucio",
      "subGroups": [
        {
          "name": "admins",
          "path": "/rucio/admins"
        },
        {
          "name": "users",
          "path": "/rucio/users"
        }
      ]
    },
    {
      "name": "atlas",
      "path": "/atlas",
      "subGroups": [
        {
          "name": "production",
          "path": "/atlas/production"
        },
        {
          "name": "users",
          "path": "/atlas/users"
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "rucio-oidc",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "rucio-oidc-secret",
      "publicClient": false,
      "redirectUris": [
        "http://rucio-oidc/auth/oidc_token",
        "http://rucio-oidc/auth/oidc_code",
        "http://rucio-oidc/auth/oidc_redirect"
      ],
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "wlcg",
        "fts",
        "storage.read",
        "storage.modify"
      ],
      "protocolMappers": [
        {
          "name": "audience-rucio-oidc",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "rucio-oidc",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-fts-oidc",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "fts-oidc",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-storm1",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "storm1",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-storm2",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "storm2",
            "access.token.claim": "true"
          }
        }
      ],
      "attributes": {
        "oidc.ciba.grant.enabled": "false",
        "oauth2.device.authorization.grant.enabled": "false",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false",
        "token.exchange.standard.flow.enabled": "true"
      }
    }
  ],
  "users": [
    {
      "username": "jdoe2",
      "enabled": true,
      "email": "jdoe2@rucio",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "secret",
          "temporary": false
        }
      ],
      "groups": [
        "/rucio/users",
        "/atlas/users"
      ]
    },
    {
      "username": "adminuser",
      "enabled": true,
      "email": "admin@rucio",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "groups": [
        "/rucio/admins",
        "/atlas/production"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "wlcg",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "wlcg-version",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "wlcg.ver",
            "claim.value": "1.0",
            "access.token.claim": "true"
          }
        },
        {
          "name": "wlcg-groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "wlcg.groups",
            "full.path": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "fts",
      "protocol": "openid-connect",
      "description": "FTS transfer scope for Rucio conveyor daemon auth"
    },
    {
      "name": "storage.read",
      "protocol": "openid-connect",
      "description": "WLCG storage read scope for TPC source token"
    },
    {
      "name": "storage.modify",
      "protocol": "openid-connect",
      "description": "WLCG storage modify scope for TPC destination token"
    }
  ],
  "sslRequired": "none"
}