{
  "realm": "rucio",
  "enabled": true,
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 1,
  "roles": {
    "realm": [
      { "name": "offline_access", "description": "Role for creating offline tokens" }
    ]
  },
  "groups": [
    {
      "name": "rucio",
      "path": "/rucio",
      "subGroups": [
        { "name": "admins", "path": "/rucio/admins" },
        { "name": "users", "path": "/rucio/users" }
      ]
    },
    {
      "name": "atlas",
      "path": "/atlas",
      "subGroups": [
        { "name": "production", "path": "/atlas/production" },
        { "name": "users", "path": "/atlas/users" }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "rucio-oidc",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "rucio-oidc-secret",
      "publicClient": false,
      "redirectUris": [
        "http://rucio-oidc/auth/oidc_token",
        "http://rucio-oidc/auth/oidc_code",
        "http://rucio-oidc/auth/oidc_redirect"
      ],
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "openid", "profile", "email", "wlcg", "fts",
        "storage.read", "storage.modify",
        "storage.read:/data", "storage.modify:/data",
        "storage.read:/", "storage.modify:/"
      ],
      "optionalClientScopes": [
        "offline_access",
        "wlcg",
        "fts",
        "storage.read",
        "storage.modify"
      ],
      "protocolMappers": [
        {
          "name": "consolidated-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "fts-oidc,STORM1,STORM2,storm1,storm2,rucio-oidc",
            "access.token.claim": "true"
          }
        }
      ],
      "attributes": {
        "oidc.ciba.grant.enabled": "false",
        "oauth2.device.authorization.grant.enabled": "false",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false",
        "token.exchange.standard.flow.enabled": "true"
      }
    },
    { "clientId": "fts-oidc", "enabled": true, "publicClient": false, "clientAuthenticatorType": "client-secret", "secret": "fts-oidc-secret" },
    { "clientId": "storm1", "enabled": true, "publicClient": true },
    { "clientId": "storm2", "enabled": true, "publicClient": true },
    { "clientId": "STORM1", "enabled": true, "publicClient": true },
    { "clientId": "STORM2", "enabled": true, "publicClient": true }
  ],
  "users": [
    {
      "username": "jdoe2",
      "enabled": true,
      "email": "jdoe2@rucio",
      "emailVerified": true,
      "realmRoles": [ "offline_access" ],
      "credentials": [
        { "type": "password", "value": "secret", "temporary": false }
      ],
      "groups": [ "/rucio/users", "/atlas/users" ]
    },
    {
      "username": "adminuser",
      "enabled": true,
      "email": "admin@rucio",
      "emailVerified": true,
      "realmRoles": [ "offline_access" ],
      "credentials": [
        { "type": "password", "value": "admin123", "temporary": false }
      ],
      "groups": [ "/rucio/admins", "/atlas/production" ]
    }
  ],
  "clientScopes": [
    {
      "name": "wlcg",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "wlcg-version",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "wlcg.ver",
            "claim.value": "1.0",
            "access.token.claim": "true"
          }
        },
        {
          "name": "wlcg-groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "wlcg.groups",
            "full.path": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    { "name": "fts", "protocol": "openid-connect" },
    { "name": "storage.read", "protocol": "openid-connect" },
    { "name": "storage.modify", "protocol": "openid-connect" },
    { "name": "storage.read:/data", "protocol": "openid-connect" },
    { "name": "storage.modify:/data", "protocol": "openid-connect" },
    { "name": "storage.read:/", "protocol": "openid-connect" },
    { "name": "storage.modify:/", "protocol": "openid-connect" }
  ],
  "sslRequired": "none"
}